## Cell 15 — Inference: score every frame in each WAV

def predict_frames(model, y, sr, device=device):
    """
    Run the trained model across an entire WAV file, one frame at a time.
    Steps every FRAME_HOP seconds, extracts a spectrogram patch,
    and returns an array of whistle probabilities — one per frame.
    Patches are batched in groups of 128 for efficiency.
    """
    total_duration = len(y) / sr
    frame_times, patches = [], []
    t = FRAME_HOP / 2
    while t < total_duration:
        patches.append(extract_patch(y, sr, t))
        frame_times.append(round(t, 3))
        t += FRAME_HOP

    probs = []
    model.eval()
    with torch.no_grad():  # inference only — no gradient tracking needed
        for i in range(0, len(patches), 128):
            batch = torch.tensor(
                np.array(patches[i : i + 128]), dtype=torch.float32
            ).to(device)
            # sigmoid converts raw logit → probability in [0, 1]
            probs.extend(torch.sigmoid(model(batch)).cpu().numpy())

    return np.array(frame_times), np.array(probs)


