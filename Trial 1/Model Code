#Cell 8 — Load SEANOE dataset

def load_seanoe_label_file(txt_path):
    """
    Parse a SEANOE Vocalization_Labels text file.
    Each line has three fields: start_sec  end_sec  label
    Returns a DataFrame with those three columns.
    """
    rows = []
    with open(txt_path) as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            parts = line.split()
            if len(parts) < 3:
                continue
            try:
                rows.append({'start': float(parts[0]),
                             'end'  : float(parts[1]),
                             'label': parts[2].upper()})
            except ValueError:
                continue
    return pd.DataFrame(rows)


def build_seanoe_dataset(seanoe_dir,
                         whistle_labels=SEANOE_WHISTLE_LABELS,
                         noise_labels=SEANOE_NOISE_LABELS,
                         max_noise_per_file=MAX_SEANOE_NOISE_PER_FILE):
    """
    Build training patches from the SEANOE public dolphin dataset.

    Positives (whistle=1):
      Pre-cut whistle clips in Whistle_Signals/ subfolders.
      Each clip is already trimmed to just the whistle, so we centre
      a single window on the whole clip.

    Negatives (noise=0):
      NOISE-labeled segments from Vocalization_Labels/ text files,
      extracted from the corresponding raw recordings in numbered subfolders.
      We slide non-overlapping windows across each NOISE segment.
      max_noise_per_file caps how many we take per recording to prevent
      SEANOE noise from overwhelming your own data.
    """
    patches, targets = [], []

    whistle_signals_dir     = os.path.join(seanoe_dir, 'Whistle_Signals')
    vocalization_labels_dir = os.path.join(seanoe_dir, 'Vocalization_Labels')

    # ── Positives: load every pre-cut whistle clip ─────────────────────────
    whistle_wavs = glob.glob(
        os.path.join(whistle_signals_dir, '**', '*.wav'), recursive=True)
    print(f'  SEANOE whistle clips found : {len(whistle_wavs)}')

    whistle_ok = 0
    for wav_path in whistle_wavs:
        try:
            y, sr = librosa.load(wav_path, sr=SR, mono=True)
            if len(y) < int(WIN_DURATION * sr / 2):
                continue  # skip clips too short for a full window
            patches.append(extract_patch_from_clip(y, sr))
            targets.append(1)
            whistle_ok += 1
        except Exception:
            continue
    print(f'  SEANOE whistle patches loaded : {whistle_ok}')

    # ── Negatives: index all raw WAV files across numbered subfolders ───────
    raw_wav_index = {}  # stem -> full path
    for entry in os.scandir(seanoe_dir):
        if not entry.is_dir():
            continue
        for wav_path in glob.glob(
                os.path.join(entry.path, '**', '*.wav'), recursive=True):
            stem = os.path.splitext(os.path.basename(wav_path))[0]
            raw_wav_index[stem] = wav_path

    txt_files = glob.glob(os.path.join(vocalization_labels_dir, '*.txt'))
    print(f'  SEANOE label files found      : {len(txt_files)}')

    noise_patches_added = 0
    for txt_path in txt_files:
        # Match label file to its raw WAV by filename stem
        stem     = os.path.splitext(os.path.basename(txt_path))[0]
        wav_path = raw_wav_index.get(stem)
        if wav_path is None:
            continue

        label_df = load_seanoe_label_file(txt_path)
        if label_df.empty or 'label' not in label_df.columns:
            continue

        # Only use rows labelled as pure NOISE
        noise_rows = label_df[label_df['label'].isin(noise_labels)]
        if noise_rows.empty:
            continue

        try:
            y, sr = librosa.load(wav_path, sr=SR, mono=True)
        except Exception:
            continue

        total_dur = len(y) / sr
        count = 0
        for _, row in noise_rows.iterrows():
            if count >= max_noise_per_file:
                break
            # Slide non-overlapping windows across each NOISE segment
            t = row.start + WIN_DURATION / 2
            while t < min(row.end, total_dur) - WIN_DURATION / 2:
                patches.append(extract_patch(y, sr, t))
                targets.append(0)
                t += WIN_DURATION
                count += 1
            noise_patches_added += 1

    print(f'  SEANOE noise patches loaded   : {noise_patches_added}')
    return patches, targets


