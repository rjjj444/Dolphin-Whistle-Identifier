## Cell 5 — Load your Raven selection tables

def parse_filename_metadata(txt_filename):
    """
    Pull the recording date, task code, and dolphin ID out of a Raven
    selection table filename. The filename encodes this metadata, e.g.:
      25-12-01_OBJ_KDK_EM_ynw_bne.Table.1.selections.txt
        → date=2025-12-01, task=OBJ, dolphin=KDK
    Handles both field orderings found in your files.
    """
    stem     = os.path.splitext(txt_filename)[0]
    # Remove the Raven-appended suffix (.Table.1.selections)
    stem     = re.sub(r'\.Table\.\d+\.selections$', '', stem)
    parts    = stem.split('_')
    # Date fields look like YY-MM-DD
    date_pat = re.compile(r'^\d{2}-\d{2}-\d{2}$')

    date_str, task, dolphin = None, None, None
    for i, p in enumerate(parts):
        if date_pat.match(p):
            yy, mm, dd = p.split('-')
            date_str = f'20{yy}-{mm}-{dd}'
            task     = parts[i - 1] if i > 0 else None        # field before date = task
            dolphin  = parts[i + 1] if i + 1 < len(parts) else None  # field after = dolphin
            break
    return date_str, task, dolphin


def load_raven_labels(raven_dir, wav_dir, exclude_annotations=None):
    """
    Read every Raven .txt selection table in raven_dir and match each one
    to its corresponding WAV file by searching recursively through wav_dir.

    For each matched pair, returns a dict:
      { wav_path -> DataFrame with 'start' and 'end' columns (seconds) }
    """
    if exclude_annotations is None:
        exclude_annotations = set()

    # Find all .txt files in the labels folder
    txt_files = sorted([f for f in os.listdir(raven_dir) if f.lower().endswith('.txt')])

    if not txt_files:
        raise FileNotFoundError(f'No .txt files found in: {raven_dir}')

    wav_labels = {}

    for txt_fname in txt_files:
        txt_path = os.path.join(raven_dir, txt_fname)

        # Read the tab-separated Raven table
        try:
            df = pd.read_csv(txt_path, sep='\t')
        except Exception as e:
            print(f'  WARNING: Could not read {txt_fname}: {e}')
            continue

        df.columns = df.columns.str.strip()  # remove any accidental whitespace in headers

        # Skip files that don't have the time columns we need
        if not {'Begin Time (s)', 'End Time (s)'}.issubset(df.columns):
            print(f'  WARNING: {txt_fname} missing time columns — skipping.')
            print(f'           Found: {list(df.columns)}')
            continue

        # Remove any selections flagged with excluded annotations
        n_before = len(df)
        if exclude_annotations and 'Annotation' in df.columns:
            df['Annotation'] = df['Annotation'].fillna('').str.strip()
            excluded = df[df['Annotation'].isin(exclude_annotations)]
            if len(excluded):
                print(f'  Excluding {len(excluded)} row(s) from {txt_fname}: '
                      f'{excluded["Annotation"].tolist()}')
            df = df[~df['Annotation'].isin(exclude_annotations)]

        # Keep only start and end times, clean up the dataframe
        labels_df = (df[['Begin Time (s)', 'End Time (s)']]
                     .copy()
                     .rename(columns={'Begin Time (s)': 'start', 'End Time (s)': 'end'})
                     .dropna()
                     .astype(float)
                     .sort_values('start')
                     .reset_index(drop=True))

        # Derive the expected WAV filename from the label filename stem
        stem     = re.sub(r'\.Table\.\d+\.selections$', '', os.path.splitext(txt_fname)[0])
        wav_name = stem + '.wav'

        # Search all subfolders of wav_dir to find the matching WAV file
        wav_path = None
        for root, dirs, files in os.walk(wav_dir):
            if wav_name in files:
                wav_path = os.path.join(root, wav_name)
                break  # stop as soon as we find it

        if wav_path is None:
            print(f'  WARNING: WAV not found anywhere under {wav_dir} for {txt_fname}')
            print(f'           Looking for: {wav_name}')
            continue

        date_str, task, dolphin = parse_filename_metadata(txt_fname)
        print(f'  ✓ {txt_fname}')
        print(f'    Date={date_str}  Task={task}  Dolphin={dolphin}')
        print(f'    Labels: {n_before} total → {len(labels_df)} kept after annotation filter')

        wav_labels[wav_path] = labels_df

    if not wav_labels:
        raise RuntimeError(
            'No WAV files could be matched to selection tables. '
            'Check that WAV filenames match your .txt filenames (same stem).'
        )
    return wav_labels


