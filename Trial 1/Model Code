## Cell 12 — CNN model definition

class WhistleCNN(nn.Module):
    """
    A 3-layer convolutional neural network that classifies mel-spectrogram
    patches as either whistle (1) or noise (0).

    Architecture:
      Feature extractor — 3 conv blocks, each with:
        Conv2d:      scans the spectrogram image with small 3x3 filters
                     to detect local patterns (edges, ridges, arcs)
        BatchNorm:   normalises activations for faster, more stable training
        ReLU:        non-linearity — lets the network learn complex patterns
        MaxPool/AvgPool: shrinks the spatial dimensions, keeping the strongest signal

      Classifier — two fully connected layers that take the extracted features
        and output a single logit (raw score before sigmoid)
        Dropout(0.4): randomly zeroes 40% of neurons during training to
                      prevent overfitting on the small whistle dataset

    Input:  (batch_size, H, W)  — a batch of 2D spectrogram patches
    Output: (batch_size,)       — one raw logit per patch
                                  apply sigmoid to get probability in [0,1]
    """
    def __init__(self):
        super().__init__()
        self.features = nn.Sequential(
            # Block 1: 1 input channel → 16 feature maps
            nn.Conv2d(1, 16, 3, padding=1), nn.BatchNorm2d(16), nn.ReLU(), nn.MaxPool2d(2),
            # Block 2: 16 → 32 feature maps
            nn.Conv2d(16, 32, 3, padding=1), nn.BatchNorm2d(32), nn.ReLU(), nn.MaxPool2d(2),
            # Block 3: 32 → 64 feature maps, then compress to fixed 4x4 spatial size
            nn.Conv2d(32, 64, 3, padding=1), nn.BatchNorm2d(64), nn.ReLU(),
            nn.AdaptiveAvgPool2d((4, 4)),
        )
        self.classifier = nn.Sequential(
            nn.Flatten(),                        # flatten 64x4x4 = 1024 values into a vector
            nn.Linear(64 * 4 * 4, 128), nn.ReLU(), nn.Dropout(0.4),
            nn.Linear(128, 1),                   # single output logit
        )

    def forward(self, x):
        # x arrives as (batch, H, W) — add channel dim to get (batch, 1, H, W)
        return self.classifier(self.features(x.unsqueeze(1))).squeeze(1)


class SpectrogramDataset(Dataset):
    """
    Wraps numpy arrays of patches and targets into a PyTorch Dataset
    so DataLoader can batch and shuffle them automatically.
    """
    def __init__(self, patches, targets):
        self.X = torch.tensor(np.array(patches), dtype=torch.float32)
        self.y = torch.tensor(np.array(targets), dtype=torch.float32)
    def __len__(self):
        return len(self.y)
    def __getitem__(self, i):
        return self.X[i], self.y[i]


