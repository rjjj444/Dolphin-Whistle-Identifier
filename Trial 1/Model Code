## Cell 4 — Feature extraction (shared by both data sources)
def extract_patch(y, sr, center_sec, duration=WIN_DURATION):
    """
    Convert a short window of raw audio into a mel-spectrogram image.
    This is the core feature the CNN learns from — not the raw waveform.

    Steps:
      1. Slice a chunk of audio centred on center_sec
      2. Zero-pad if the chunk is too short (e.g. near the start/end of the file)
      3. Compute mel-spectrogram: frequency vs time, weighted by human hearing
      4. Convert power to decibels (log scale matches how we perceive loudness)
      5. Normalise to [0, 1] so all patches have the same contrast range
    """
    start_sec    = center_sec - duration / 2
    start_sample = max(0, int(start_sec * sr))
    chunk        = y[start_sample : start_sample + int(duration * sr)]
    target_len   = int(duration * sr)

    if len(chunk) < target_len:
        chunk = np.pad(chunk, (0, target_len - len(chunk)))  # zero-pad short chunks

    S    = librosa.feature.melspectrogram(
               y=chunk, sr=sr, n_mels=N_MELS,
               hop_length=HOP_LENGTH, fmax=sr // 2)
    S_db = librosa.power_to_db(S, ref=np.max)
    # Normalise to [0,1] range
    S_db = (S_db - S_db.min()) / (S_db.max() - S_db.min() + 1e-8)
    return S_db.astype(np.float32)


def extract_patch_from_clip(y, sr, duration=WIN_DURATION):
    """
    Simpler version for SEANOE pre-cut clips that are already short.
    Since the whole clip is a whistle, we just centre the window on the middle.
    """
    center = len(y) / sr / 2
    return extract_patch(y, sr, center, duration)


