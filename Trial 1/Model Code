#Cell 16 — Segment detection and clip extraction

def to_mmss(s):
    """Convert seconds to M:SS.ss timestamp string for readability."""
    m = int(s) // 60
    return f'{m}:{s - m * 60:05.2f}'


def save_frame_csv(frame_times, probs, threshold, output_dir, wav_stem):
    """
    Save a CSV of frame-level predictions for the full recording.
    Columns: time_sec, timestamp, probability, whistle (0 or 1)
    Useful for inspecting exactly where the model is confident vs uncertain.
    """
    df = pd.DataFrame({
        'time_sec'   : frame_times,
        'timestamp'  : [to_mmss(t) for t in frame_times],
        'probability': np.round(probs, 4),
        'whistle'    : (probs >= threshold).astype(int),
    })
    csv_path = os.path.join(output_dir, f'{wav_stem}_predictions.csv')
    df.to_csv(csv_path, index=False)
    print(f'  Frame CSV → {os.path.basename(csv_path)}')
    return df


def frames_to_segments(frame_times, probs,
                        threshold=THRESHOLD,
                        min_gap=MIN_GAP,
                        min_duration=MIN_DURATION):
    """
    Convert per-frame probabilities into (start, end) whistle event timestamps.

    Steps:
      1. Threshold: any frame with prob >= threshold is marked as whistle
      2. State machine: track transitions from noise→whistle (start) and
         whistle→noise (end) to build raw segment boundaries
      3. Merge: if two segments are separated by less than min_gap seconds,
         join them into one (handles brief probability dips mid-whistle)
      4. Filter: discard any segment shorter than min_duration seconds
         (removes spurious single-frame detections)
    """
    labels     = probs >= threshold
    segments   = []
    in_whistle = False
    seg_start  = None

    for t, is_on in zip(frame_times, labels):
        if is_on and not in_whistle:       # noise → whistle transition
            seg_start  = t - FRAME_HOP / 2
            in_whistle = True
        elif not is_on and in_whistle:     # whistle → noise transition
            segments.append([seg_start, t - FRAME_HOP / 2])
            in_whistle = False

    if in_whistle:  # whistle runs all the way to end of file
        segments.append([seg_start, frame_times[-1] + FRAME_HOP / 2])

    if not segments:
        return []

    # Merge segments that are close together
    merged = [segments[0]]
    for start, end in segments[1:]:
        if start - merged[-1][1] <= min_gap:
            merged[-1][1] = max(merged[-1][1], end)  # extend current segment
        else:
            merged.append([start, end])               # start a new segment

    # Drop segments that are too short to be real whistles
    return [(s, e) for s, e in merged if (e - s) >= min_duration]


def save_whistle_clips(y, sr, segments, output_dir, wav_stem, padding=PADDING):
    """
    For each detected whistle segment, slice that portion of audio
    and save it as an individual WAV file with a small padding buffer.
    Files are named with the whistle index and exact timestamps.
    """
    total_dur = len(y) / sr
    saved = []
    for i, (start, end) in enumerate(segments):
        s     = max(0.0, start - padding)   # add padding but don't go before 0
        e     = min(total_dur, end + padding)  # add padding but don't exceed file length
        chunk = y[int(s * sr) : int(e * sr)]
        fname = os.path.join(
            output_dir,
            f'{wav_stem}__whistle_{i+1:04d}_{s:.3f}-{e:.3f}s.wav'
        )
        sf.write(fname, chunk, sr)
        saved.append(fname)
        print(f'    [{i+1:04d}]  {s:.2f}s – {e:.2f}s  ({e-s:.2f}s)')
    return saved


