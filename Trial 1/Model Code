## Cell 11 — Oversample minority class

def oversample_minority(patches, targets, target_ratio=OVERSAMPLE_RATIO):
    """
    Whistle frames are naturally rare — maybe 1 in 50 frames in a long recording.
    If we trained on this imbalanced data directly, the model would learn to
    just predict 'noise' for everything and still get 98% accuracy.

    Fix: duplicate whistle frames (with tiny random noise added so they're not
    exact copies) until the noise:whistle ratio is no worse than target_ratio.
    The noise jitter also acts as light data augmentation.
    """
    patches = np.array(patches)
    targets = np.array(targets)
    pos_idx = np.where(targets == 1)[0]  # indices of whistle frames
    n_pos   = len(pos_idx)
    n_neg   = int((targets == 0).sum())

    if n_pos == 0:
        return patches, targets  # nothing to oversample

    # How many whistle frames do we need to reach the target ratio?
    desired_pos = max(n_pos, int(n_neg / target_ratio))
    rng = np.random.default_rng(42)  # fixed seed for reproducibility

    if desired_pos > n_pos:
        # Randomly pick existing whistle frames to duplicate
        extra_idx     = rng.choice(pos_idx, size=desired_pos - n_pos, replace=True)
        extra_patches = patches[extra_idx].copy()
        # Add tiny Gaussian noise as light augmentation
        extra_patches += rng.normal(0, 0.01, extra_patches.shape).astype(np.float32)
        extra_patches  = np.clip(extra_patches, 0, 1)  # keep values in valid range
        patches = np.concatenate([patches, extra_patches], axis=0)
        targets = np.concatenate([targets, np.ones(len(extra_idx))], axis=0)

    # Shuffle so whistle and noise frames are mixed throughout each batch
    shuffle = rng.permutation(len(targets))
    return patches[shuffle], targets[shuffle]


