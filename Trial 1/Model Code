## Cell 13 — Train the model

def train_model(patches, targets, epochs=EPOCHS, device=device):
    """
    Full training loop:
      1. Oversample whistle frames to fix class imbalance
      2. Split into 85% train / 15% validation
      3. For each epoch:
           - Forward pass: feed patches through CNN, get logits
           - Compute BCE loss: how wrong were the predictions?
           - Backward pass: compute gradients
           - Update weights: Adam optimizer step
           - Validate on held-out set
           - Reduce learning rate if val loss plateaus (ReduceLROnPlateau)
           - Save best model weights seen so far
      4. Restore best weights and print final classification report
    """
    patches = np.array(patches)
    targets = np.array(targets)

    n_pos = int(targets.sum())
    n_neg = int(len(targets) - n_pos)
    print(f'Before oversampling: whistle={n_pos}, noise={n_neg}  (ratio 1:{n_neg // max(n_pos,1)})')

    patches, targets = oversample_minority(patches, targets)

    n_pos2 = int(targets.sum())
    n_neg2 = int(len(targets) - n_pos2)
    print(f'After  oversampling: whistle={n_pos2}, noise={n_neg2}  (ratio 1:{n_neg2 // max(n_pos2,1)})')

    # Stratified split keeps the same whistle:noise ratio in both sets
    X_tr, X_val, y_tr, y_val = train_test_split(
        patches, targets, test_size=0.15, stratify=targets, random_state=42)

    train_dl = DataLoader(SpectrogramDataset(X_tr,  y_tr),  batch_size=BATCH_SIZE, shuffle=True)
    val_dl   = DataLoader(SpectrogramDataset(X_val, y_val), batch_size=BATCH_SIZE)

    # BCEWithLogitsLoss = binary cross-entropy, numerically stable version
    # (combines sigmoid + BCE in one operation)
    criterion = nn.BCEWithLogitsLoss()
    model     = WhistleCNN().to(device)
    optimizer = optim.Adam(model.parameters(), lr=LEARN_RATE)
    # Halve the learning rate if validation loss doesn't improve for 4 epochs
    scheduler = optim.lr_scheduler.ReduceLROnPlateau(optimizer, patience=4, factor=0.5)

    best_val_loss = float('inf')
    best_state    = None
    history       = {'train': [], 'val': []}

    print(f'\nTraining for {epochs} epochs on {device}...\n')

    for epoch in range(1, epochs + 1):
        # ── Training pass ──
        model.train()  # enable dropout and batchnorm training behaviour
        train_loss = 0.0
        for xb, yb in train_dl:
            xb, yb = xb.to(device), yb.to(device)
            optimizer.zero_grad()          # clear gradients from previous step
            loss = criterion(model(xb), yb)  # forward pass + loss
            loss.backward()                # backprop: compute gradients
            optimizer.step()               # update weights
            train_loss += loss.item() * len(yb)
        train_loss /= len(train_dl.dataset)

        # ── Validation pass ──
        model.eval()   # disable dropout, use running stats for batchnorm
        val_loss = 0.0
        with torch.no_grad():  # no gradients needed during validation
            for xb, yb in val_dl:
                val_loss += criterion(model(xb.to(device)), yb.to(device)).item() * len(yb)
        val_loss /= len(val_dl.dataset)

        scheduler.step(val_loss)  # possibly reduce learning rate
        history['train'].append(train_loss)
        history['val'].append(val_loss)

        # Save the best model weights seen so far
        if val_loss < best_val_loss:
            best_val_loss = val_loss
            best_state    = {k: v.clone() for k, v in model.state_dict().items()}
            marker        = ' ← best'
        else:
            marker = ''

        print(f'Epoch {epoch:3d}/{epochs}  train={train_loss:.4f}  val={val_loss:.4f}{marker}')

    # Restore the best weights before returning
    model.load_state_dict(best_state)

    # Final report on the validation set using the best model
    model.eval()
    preds, trues = [], []
    with torch.no_grad():
        for xb, yb in val_dl:
            logits = model(xb.to(device))
            # Apply sigmoid to convert logit → probability, then threshold
            preds.extend((torch.sigmoid(logits) > THRESHOLD).cpu().numpy().astype(int))
            trues.extend(yb.numpy().astype(int))

    print('\n── Validation Classification Report ──')
    print(classification_report(trues, preds,
                                 target_names=['noise', 'whistle'],
                                 zero_division=0))
    return model, history


