#Cell 7 — Build dataset from your recordings

def frame_is_whistle(t_center, labels_df):
    """
    Decide if a frame centred at t_center overlaps any labeled whistle.
    Uses direct interval overlap — if the frame window touches a whistle
    window at all, the frame is labelled as whistle (1), otherwise noise (0).
    This is simpler and more accurate than the original IoU approach because
    we have real end times from Raven rather than assumed durations.
    """
    t_start = t_center - FRAME_HOP / 2
    t_end   = t_center + FRAME_HOP / 2
    for _, row in labels_df.iterrows():
        if t_start < row.end and t_end > row.start:  # any overlap = whistle
            return True
    return False


def build_own_dataset(wav_labels):
    """
    Slide a frame window across every WAV file at FRAME_HOP intervals.
    For each frame, extract a mel-spectrogram patch and assign a label:
      1 = whistle (frame overlaps a Raven-labeled whistle interval)
      0 = noise   (frame doesn't overlap any labeled interval)

    Returns all patches, all labels, and a cache of loaded audio
    (wav_audio) so we don't have to reload files during inference.
    """
    patches, targets = [], []
    wav_audio = {}  # cache: {wav_path -> (y, sr)}

    for wav_path, labels_df in wav_labels.items():
        fname = os.path.basename(wav_path)
        print(f'  Loading: {fname}')
        # Load audio, resampling to SR and converting to mono
        y, sr = librosa.load(wav_path, sr=SR, mono=True)
        print(f'    Duration : {len(y)/sr:.1f}s  ({len(y)/sr/60:.1f} min)')
        wav_audio[wav_path] = (y, sr)  # cache for later inference

        total_dur = len(y) / sr
        t = FRAME_HOP / 2  # start half a frame in so the first window is centred correctly
        file_patches, file_targets = [], []

        while t < total_dur:
            file_patches.append(extract_patch(y, sr, t))
            file_targets.append(1 if frame_is_whistle(t, labels_df) else 0)
            t += FRAME_HOP

        n_pos = sum(file_targets)
        n_neg = len(file_targets) - n_pos
        print(f'    Frames : {len(file_targets)} total  |  whistle={n_pos}  noise={n_neg}')

        patches.extend(file_patches)
        targets.extend(file_targets)

    return patches, targets, wav_audio


